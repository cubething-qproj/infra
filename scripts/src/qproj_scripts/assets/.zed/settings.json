{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "features": "all",
        },
        "check": {
          "overrideCommand": ["just", "ra-check"],
          "features": "all",
          "workspace": false,
        },
      },
    },
    "basedpyright": {
      "settings": {
        "logLevel": "Warn",
      },
    },
  },
  "languages": {
    "Python": {
      "language_servers": ["ruff", "basedpyright"],
    },
  },
}
