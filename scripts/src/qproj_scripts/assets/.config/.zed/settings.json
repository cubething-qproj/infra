{
  "file_scan_exclusions": [
    "**/.bare",
    "**/.direnv",
    "**/target",
    "main",
    "feat",
    "fix",
    "doc",
    "tests",
    "release"
  ],
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "linkedProjects": ["./active/Cargo.toml"],
        "cargo": { "features": "all" },
        "check": {
          "overrideCommand": ["just", "ra-check"],
          "features": "all",
          "workspace": false
        }
      }
    }
  }
}
