# Metarepo-root justfile (symlinked into each <repo>/ from .config/).
# Holds cross-cutting verbs only -- per-crate recipes (build, play,
# check, ...) live in <wt>/justfile, sourced from
# infra/config/worktree.justfile, and reached here via the import
# below so `cd <repo> && just play` continues to work by delegating to
# whichever worktree is checked out at active/.

import? 'active/justfile'

QPROJ_REF := env("QPROJ_SCRIPTS_REF", "main")
QPROJ_GIT_URL := "git+https://github.com/cubething-qproj/infra.git@" + QPROJ_REF + "#subdirectory=scripts"
SCRIPTS_SRC := env("QPROJ_SCRIPTS_SRC", QPROJ_GIT_URL)
qproj := "qproj-scripts"

_default:
    just --list

# Set up and synchronize proj repos.
sync *args:
    {{ qproj }} sync {{ args }}

sync-scripts:
    uv tool install qproj-scripts --from {{ SCRIPTS_SRC }}

# Change where 'active' points to.
target dir:
    {{ qproj }} target {{ dir }}

# Create a new worktree.
add name:
    {{ qproj }} add {{ name }}

# Prune merged branches.
prune:
    {{ qproj }} prune
