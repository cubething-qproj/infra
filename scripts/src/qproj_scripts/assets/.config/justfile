# Metarepo-root justfile. Cross-cutting verbs only; per-crate recipes
# (build, play, check, ...) live in the active worktree's justfile,
# imported below so `cd <repo> && just play` reaches them.

import? 'active/justfile'

QPROJ_REF := env("QPROJ_SCRIPTS_REF", "main")
QPROJ_GIT_URL := "git+https://github.com/cubething-qproj/infra.git@" + QPROJ_REF + "#subdirectory=scripts"
SCRIPTS_SRC := env("QPROJ_SCRIPTS_SRC", QPROJ_GIT_URL)
qproj := "qproj-scripts"

_default:
    just --list

# Set up and synchronize proj repos.
sync *args:
    {{ qproj }} sync {{ args }}

sync-scripts:
    uv tool install qproj-scripts --from {{ SCRIPTS_SRC }}

# Check out a branch in active/.
target *args:
    {{ qproj }} target {{ args }}

# Create a new worktree.
add *args:
    {{ qproj }} add {{ args }}

# Initialize a new downstream repo under cubething-qproj/.
init *args:
    {{ qproj }} init {{ args }}

# Prune merged branches.
prune *args:
    {{ qproj }} prune {{ args }}
